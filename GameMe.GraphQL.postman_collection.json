{
  "info": {
    "name": "GameMe GraphQL API",
    "description": "GraphQL API collection for GameMe. Run 'Auth → Login' first — the token is saved automatically to all requests.\n\nStart the backend with: mvn spring-boot:run -Dspring-boot.run.arguments=-d",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "10",
      "type": "string",
      "description": "Change this to a valid user ID from your database"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test10@test.com\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and save JWT token. Token is automatically saved to {{token}} variable."
          }
        }
      ]
    },
    {
      "name": "Queries",
      "item": [
        {
          "name": "me",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  me {\n    id\n    nickname\n    email\n    profilePicture\n    bio {\n      dateOfBirth\n      gender\n      country\n      city\n    }\n    profile {\n      aboutMe\n    }\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Get the currently authenticated user."
          }
        },
        {
          "name": "user(id)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetUser($id: ID!) {\n  user(id: $id) {\n    id\n    nickname\n    profilePicture\n    bio {\n      country\n      city\n      gender\n      preferences {\n        gamePreference\n        intensity\n      }\n    }\n    profile {\n      aboutMe\n    }\n  }\n}",
                "variables": "{\n  \"id\": \"{{userId}}\"\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Get a user by ID. Change {{userId}} variable at the collection level."
          }
        },
        {
          "name": "bio(id)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetBio($id: ID!) {\n  bio(id: $id) {\n    dateOfBirth\n    gender\n    country\n    city\n    preferences {\n      timeRange\n      timeZone\n      gamePreference\n      gameGenrePreference\n      platforms\n      intensity\n      lookingFor\n    }\n    user {\n      id\n      nickname\n    }\n  }\n}",
                "variables": "{\n  \"id\": \"{{userId}}\"\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Get bio by user ID. Includes back-reference to User."
          }
        },
        {
          "name": "profile(id)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetProfile($id: ID!) {\n  profile(id: $id) {\n    aboutMe\n    user {\n      id\n      nickname\n    }\n  }\n}",
                "variables": "{\n  \"id\": \"{{userId}}\"\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Get profile by user ID. Includes back-reference to User."
          }
        },
        {
          "name": "myBio",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  myBio {\n    dateOfBirth\n    gender\n    country\n    city\n    preferences {\n      timeRange\n      timeZone\n      gamePreference\n      gameGenrePreference\n      platforms\n      intensity\n      lookingFor\n      preferredGenders\n      preferredAgeMin\n      preferredAgeMax\n      maxDistanceKm\n    }\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Get the authenticated user's full bio including private preference fields."
          }
        },
        {
          "name": "myProfile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  myProfile {\n    aboutMe\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "recommendations (single query)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  recommendations {\n    id\n    nickname\n    profilePicture\n    bio {\n      dateOfBirth\n      gender\n      country\n      city\n      preferences {\n        timeRange\n        gamePreference\n        gameGenrePreference\n        platforms\n        intensity\n        lookingFor\n      }\n    }\n    profile {\n      aboutMe\n    }\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Get all recommendation data (name, picture, bio, profile) in a single query."
          }
        },
        {
          "name": "connections",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  connections {\n    id\n    nickname\n    profilePicture\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "incomingConnections",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  incomingConnections {\n    id\n    nickname\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "outgoingConnections",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  outgoingConnections {\n    id\n    nickname\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        }
      ]
    },
    {
      "name": "Mutations",
      "item": [
        {
          "name": "updateProfile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  updateProfile(aboutMe: \"Updated about me text\") {\n    aboutMe\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "updateAccount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  updateAccount(input: {\n    nickname: \"NewNickname\"\n  }) {\n    id\n    nickname\n    email\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "updateBio",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  updateBio(input: {\n    country: \"Estonia\",\n    city: \"Tallinn\",\n    latitude: 59.4370,\n    longitude: 24.7536,\n    maxDistanceKm: 100\n  }) {\n    country\n    city\n    preferences {\n      maxDistanceKm\n    }\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "sendConnectionRequest",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  sendConnectionRequest(userId: \"{{userId}}\")\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Change {{userId}} to a user that appears in your recommendations."
          }
        },
        {
          "name": "acceptConnection",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  acceptConnection(userId: \"{{userId}}\")\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "rejectConnection",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  rejectConnection(userId: \"{{userId}}\")\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "blockUser",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  blockUser(userId: \"{{userId}}\")\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "removeConnection",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  removeConnection(userId: \"{{userId}}\")\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "setOnline",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  setOnline\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Mark the current user as online. Used to trigger onlineStatus subscription events."
          }
        },
        {
          "name": "setOffline",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  setOffline\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        }
      ]
    }
  ]
}
