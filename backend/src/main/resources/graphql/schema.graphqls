#Retrieve data
type Query {
    user(id: ID!): User,
    bio(id: ID!): Bio,
    profile(id: ID!): Profile,
    me: User,
    myBio: Bio,
    myProfile: Profile,
    recommendations: [User],
    connections: [User]
}

type Mutation {
    updateAccount(input: UpdateAccountInput!): User,
    updateBio(input: UpdateBioInput!): Bio,
    updateProfile(aboutMe: String!): Profile
}


input UpdateAccountInput {
    nickname: String,
    email: String,
    currentPassword: String,
    newPassword: String
}

input UpdateBioInput {
    dateOfBirth: String,
    gender: String,
    country: String,
    city: String,
    latitude: Float,
    longitude: Float,
    timeRange: String,
    timeZone: String,
    gamePreference: String,
    gameGenrePreference: String,
    lookingFor: String,
    platforms: String,
    intensity: String,
    preferredGenders: String,
    preferredAgeMin: Int,
    preferredAgeMax: Int,
    maxDistanceKm: Int,
}

type User {
    id: ID!,
    nickname: String,
    profilePicture: String,
    email: String,
    bio: Bio,
    profile: Profile
}

type Bio {
    dateOfBirth: String,
    gender: String,
    country: String,
    city: String,
    preferences: Preferences,
    user: User
}

type Profile {
    aboutMe: String,
    user: User
}

type Preferences {
    timeRange: String,
    timeZone: String,
    gamePreference: String,
    gameGenrePreference: String,
    lookingFor: String,
    platforms: String,
    intensity: String,
    preferredGenders: String,
    preferredAgeMin: Int,
    preferredAgeMax: Int,
    maxDistanceKm: Int,
}